---
import { SEO } from 'astro-seo';
const { frontmatter, pageMeta } = Astro.props;
import Fonts from '../components/Fonts.astro';
const siteURL = 'https://hellostu.xyz';

// Determine the slug to find the generated OG image.
// We handle posts (frontmatter) and static pages (pageMeta or URL path).
const urlPath = Astro.url.pathname.replace(/\/$/, '');
const urlSlug = urlPath.split('/').pop() || 'index';
const activeSlug = frontmatter?.slug || pageMeta?.slug || urlSlug;

const ogImage = `${siteURL}/generated_OG_images/${activeSlug}.png`;

const title =
  pageMeta?.title ||
  (frontmatter?.title ? `Hello Stu | ${frontmatter.title}` : 'Hello Stu');
const description = frontmatter?.description || pageMeta?.description || '';
---

<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.png" />
  <link rel="webmention" href="https://webmention.io/hellostu.xyz/webmention" />
  <link rel="pingback" href="https://webmention.io/hellostu.xyz/xmlrpc" />
  <meta name="viewport" content="width=device-width" />
  <meta name="generator" content={Astro.generator} />
  <Fonts />
  <SEO
    title={title}
    description={description}
    openGraph={{
      basic: {
        title: title,
        type: frontmatter !== undefined ? 'article' : 'website',
        image: ogImage,
      },
      optional: {
        description: description,
      },
      article: { authors: ['Stuart Mackenzie'] },
    }}
    twitter={{
      creator: '@_disco',
      card: 'summary_large_image',
      title: title,
      image: ogImage,
      description: description,
    }}
  />
</head>
