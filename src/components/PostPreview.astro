---
const { data } = Astro.props;
// Hybrid image resolver: supports both string paths and imported images

function resolveImage(src) {
  // If src is an object (imported image), return src.src
  if (typeof src === 'object' && src !== null && 'src' in src) return src.src;
  // If src is a string, return as-is
  return src;
}
const dateOptions: object = {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
};
const formattedPublishDate = new Date(data.pubDate).toLocaleDateString(
  'en-UK',
  dateOptions,
);
---

<article>
  <img
    src={`/generated_preview_images/${data.slug}.png`}
    alt={`Preview image for ${data.title}`}
    width="300"
    loading="lazy"
    style="object-fit:cover;max-width:100%;height:auto;aspect-ratio:600/315;"
  />
  <a href={`/posts/${data.slug}`}><h3>{data.title}</h3></a>
  <p>{formattedPublishDate}</p>
  <p>{data.description}</p>
  <p>
    {
      data.tags.map(tag => (
        <span class="smalltag">
          <a href={`/tags/${tag}`}>#{tag}</a>
        </span>
      ))
    }
  </p>
</article>
